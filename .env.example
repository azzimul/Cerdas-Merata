# ── Mode ─────────────────────────────────────────────────────────────────────
# Set to 1 to use SQLite (no PostgreSQL needed — for local demo only)
USE_SQLITE=0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Option A: full connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/cerdas_merata

# Option B: individual parts (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cerdas_merata
DB_USER=postgres
DB_PASS=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_ID=admin01
ADMIN_PASS=admin123

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=1

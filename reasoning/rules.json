{
  "version": "1.3",
  "description": "12 IF-THEN Forward Chaining rules — 5 categories — Cerdas Merata",
  "max_score_teoritis": 45,
  "categories": ["kemiskinan", "tanggungan", "infrastruktur", "sosial", "prestasi"],
  "rules": [
    {
      "id": "A1",
      "category": "kemiskinan",
      "description": "Income = 0 (no income)",
      "condition": {"field": "pendapatan_ortu", "op": "eq", "value": 0},
      "points": 10,
      "label": "Critical poverty score"
    },
    {
      "id": "A2",
      "category": "kemiskinan",
      "description": "Income < Rp 1,000,000",
      "condition": {"field": "pendapatan_ortu", "op": "lt", "value": 1000000},
      "points": 8,
      "label": "Very high poverty score"
    },
    {
      "id": "A3",
      "category": "kemiskinan",
      "description": "Income Rp 1,000,000 – 1,999,999",
      "condition": {"field": "pendapatan_ortu", "op": "between", "min": 1000000, "max": 1999999},
      "points": 6,
      "label": "High poverty score"
    },
    {
      "id": "A4",
      "category": "kemiskinan",
      "description": "Income Rp 2,000,000 – 2,999,999",
      "condition": {"field": "pendapatan_ortu", "op": "between", "min": 2000000, "max": 2999999},
      "points": 4,
      "label": "Moderate poverty score"
    },
    {
      "id": "A5",
      "category": "kemiskinan",
      "description": "Income Rp 3,000,000 – 4,500,000",
      "condition": {"field": "pendapatan_ortu", "op": "between", "min": 3000000, "max": 4500000},
      "points": 2,
      "label": "Low poverty score"
    },
    {
      "id": "B1",
      "category": "tanggungan",
      "description": "4 dependents",
      "condition": {"field": "jumlah_tanggungan", "op": "gte", "value": 4},
      "points": 6,
      "label": "Very high dependent burden"
    },
    {
      "id": "B2",
      "category": "tanggungan",
      "description": "3 dependents",
      "condition": {"field": "jumlah_tanggungan", "op": "eq", "value": 3},
      "points": 4,
      "label": "High dependent burden"
    },
    {
      "id": "B3",
      "category": "tanggungan",
      "description": "2 dependents",
      "condition": {"field": "jumlah_tanggungan", "op": "eq", "value": 2},
      "points": 2,
      "label": "Moderate dependent burden"
    },
    {
      "id": "C1",
      "category": "infrastruktur",
      "description": "Electricity bill = 0 / no electricity",
      "condition": {"field": "tagihan_listrik", "op": "eq", "value": 0},
      "points": 6,
      "label": "Extreme infrastructure limitation"
    },
    {
      "id": "C2",
      "category": "infrastruktur",
      "description": "Electricity bill < Rp 100,000 / month",
      "condition": {"field": "tagihan_listrik", "op": "lt", "value": 100000},
      "points": 4,
      "label": "High economic limitation"
    },
    {
      "id": "C3",
      "category": "infrastruktur",
      "description": "Electricity bill Rp 100,000 – 199,999 / month",
      "condition": {"field": "tagihan_listrik", "op": "between", "min": 100000, "max": 199999},
      "points": 2,
      "label": "Moderate economic limitation"
    },
    {
      "id": "C4",
      "category": "infrastruktur",
      "description": "Electricity bill Rp 200,000 – 350,000 / month",
      "condition": {"field": "tagihan_listrik", "op": "between", "min": 200000, "max": 350000},
      "points": 1,
      "label": "Low economic limitation"
    },
    {
      "id": "C5",
      "category": "infrastruktur",
      "description": "Installed electricity = 450 VA",
      "condition": {"field": "wattage_listrik", "op": "eq", "value": 450},
      "points": 5,
      "label": "High infrastructure limitation"
    },
    {
      "id": "C6",
      "category": "infrastruktur",
      "description": "Installed electricity = 900 VA",
      "condition": {"field": "wattage_listrik", "op": "eq", "value": 900},
      "points": 3,
      "label": "Moderate infrastructure limitation"
    },
    {
      "id": "C7",
      "category": "infrastruktur",
      "description": "Installed electricity = 1300 VA",
      "condition": {"field": "wattage_listrik", "op": "eq", "value": 1300},
      "points": 1,
      "label": "Low infrastructure limitation"
    },
    {
      "id": "D1",
      "category": "sosial",
      "description": "Parent status = Both parents deceased",
      "condition": {"field": "status_ortu", "op": "eq", "value": "yatim_piatu"},
      "points": 5,
      "label": "Critical family condition"
    },
    {
      "id": "D2",
      "category": "sosial",
      "description": "Parent status = Father or mother deceased",
      "condition": {"field": "status_ortu", "op": "in", "values": ["yatim", "piatu"]},
      "points": 3,
      "label": "Severe family condition"
    },
    {
      "id": "D3",
      "category": "sosial",
      "description": "Parent occupation = Unemployed",
      "condition": {"field": "pekerjaan_ortu", "op": "eq", "value": "tidak_bekerja"},
      "points": 5,
      "label": "Critical vulnerable sector"
    },
    {
      "id": "D4",
      "category": "sosial",
      "description": "Parent occupation = Laborer / Farmer",
      "condition": {"field": "pekerjaan_ortu", "op": "eq", "value": "buruh_petani"},
      "points": 3,
      "label": "High vulnerable sector"
    },
    {
      "id": "D5",
      "category": "sosial",
      "description": "Parent occupation = Small Trader",
      "condition": {"field": "pekerjaan_ortu", "op": "eq", "value": "pedagang_kecil"},
      "points": 2,
      "label": "Moderate vulnerable sector"
    },
    {
      "id": "E1",
      "category": "prestasi",
      "description": "GPA >= 3.7",
      "condition": {"field": "ipk", "op": "gte_scaled", "value_4scale": 3.7, "value_100scale": 90},
      "points": 5,
      "label": "Excellent academic achievement"
    },
    {
      "id": "E2",
      "category": "prestasi",
      "description": "GPA 3.5 – 3.69",
      "condition": {"field": "ipk", "op": "between_scaled", "min_4scale": 3.5, "max_4scale": 3.69, "min_100scale": 85, "max_100scale": 89},
      "points": 4,
      "label": "Very good academic achievement"
    },
    {
      "id": "E3",
      "category": "prestasi",
      "description": "GPA 3.0 – 3.49",
      "condition": {"field": "ipk", "op": "between_scaled", "min_4scale": 3.0, "max_4scale": 3.49, "min_100scale": 75, "max_100scale": 84},
      "points": 2,
      "label": "Good academic achievement"
    },
    {
      "id": "E4",
      "category": "prestasi",
      "description": "GPA 2.5 – 2.99",
      "condition": {"field": "ipk", "op": "between_scaled", "min_4scale": 2.5, "max_4scale": 2.99, "min_100scale": 65, "max_100scale": 74},
      "points": 1,
      "label": "Satisfactory academic achievement"
    },
    {
      "id": "E5",
      "category": "prestasi",
      "description": "Currently receiving another scholarship = Yes",
      "condition": {"field": "bantuan_lain", "op": "eq", "value": true},
      "points": -8,
      "label": "Priority deduction (active scholarship)"
    }
  ],
  "anomaly_rules": [
    {
      "id": "ANO1",
      "description": "450 VA electricity but income > Rp 5,000,000 — inconsistent data",
      "conditions": [
        {"field": "wattage_listrik", "op": "eq", "value": 450},
        {"field": "pendapatan_ortu", "op": "gt", "value": 5000000}
      ]
    },
    {
      "id": "ANO2",
      "description": "Income = 0 but electricity bill > Rp 500,000 — inconsistent data",
      "conditions": [
        {"field": "pendapatan_ortu", "op": "eq", "value": 0},
        {"field": "tagihan_listrik", "op": "gt", "value": 500000}
      ]
    },
    {
      "id": "ANO3",
      "description": "Income = 0 but electricity >= 2200 VA — inconsistent data",
      "conditions": [
        {"field": "pendapatan_ortu", "op": "eq", "value": 0},
        {"field": "wattage_listrik", "op": "gte", "value": 2200}
      ]
    }
  ],
  "exclusive_category_groups": [
    ["A1", "A2", "A3", "A4", "A5"],
    ["B1", "B2", "B3"],
    ["C1", "C2", "C3", "C4"],
    ["C5", "C6", "C7"],
    ["D1", "D2"],
    ["D3", "D4", "D5"],
    ["E1", "E2", "E3", "E4"]
  ]
}
